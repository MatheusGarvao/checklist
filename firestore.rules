rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowed() {
      return request.auth != null
        && request.auth.token.email in [
          "theuspsg@gmail.com",
          "aly0ciah@gmail.com"
        ];
    }

    function isAllowedEmail(email) {
      return email in [
        "theuspsg@gmail.com",
        "aly0ciah@gmail.com"
      ];
    }

    function isValidFavoriteBy(favoriteBy) {
      return favoriteBy is map
        && favoriteBy.keys().hasOnly(["matheus", "aly"])
        && (!favoriteBy.keys().hasAny(["matheus"]) || favoriteBy.matheus is bool)
        && (!favoriteBy.keys().hasAny(["aly"]) || favoriteBy.aly is bool);
    }

    function isValidDeleteConfirm(confirm) {
      return confirm is map
        && confirm.keys().hasOnly([
          "itemId",
          "itemName",
          "requestedBy",
          "requestedByEmail"
        ])
        && confirm.itemId is string
        && confirm.itemName is string
        && confirm.itemName.size() <= 120
        && confirm.requestedBy is string
        && confirm.requestedBy.size() <= 40
        && confirm.requestedByEmail is string
        && isAllowedEmail(confirm.requestedByEmail);
    }

    function isValidLinkDeleteConfirm(confirm) {
      return confirm is map
        && confirm.keys().hasOnly([
          "itemId",
          "itemName",
          "linkId",
          "linkTitle",
          "requestedBy",
          "requestedByEmail"
        ])
        && confirm.itemId is string
        && confirm.itemName is string
        && confirm.itemName.size() <= 120
        && confirm.linkId is string
        && confirm.linkTitle is string
        && confirm.linkTitle.size() <= 240
        && confirm.requestedBy is string
        && confirm.requestedBy.size() <= 40
        && confirm.requestedByEmail is string
        && isAllowedEmail(confirm.requestedByEmail);
    }

    function isValidItem() {
      return request.resource.data.keys().hasOnly([
          "name",
          "value",
          "categories",
          "favoriteBy",
          "checked",
          "links",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.value is number
        && request.resource.data.value >= 0
        && request.resource.data.value <= 10000000
        && request.resource.data.checked is bool
        && request.resource.data.categories is list
        && request.resource.data.categories.size() <= 20
        && (
          !request.resource.data.keys().hasAny(["favoriteBy"])
          || isValidFavoriteBy(request.resource.data.favoriteBy)
        )
        && request.resource.data.links is list
        && request.resource.data.links.size() <= 100
        && (
          !request.resource.data.keys().hasAny(["createdAt"])
          || request.resource.data.createdAt is timestamp
        )
        && (
          !request.resource.data.keys().hasAny(["updatedAt"])
          || request.resource.data.updatedAt is timestamp
        );
    }

    function isValidFilters() {
      return request.resource.data.keys().hasOnly([
          "searchTerm",
          "selectedCategories",
          "favoriteFilters",
          "favoritesOnly",
          "purchaseFilter",
          "updatedAt",
          "updatedBy"
        ])
        && request.resource.data.searchTerm is string
        && request.resource.data.searchTerm.size() <= 120
        && request.resource.data.selectedCategories is list
        && request.resource.data.selectedCategories.size() <= 50
        && (
          !request.resource.data.keys().hasAny(["favoriteFilters"])
          || (
            request.resource.data.favoriteFilters is list
            && request.resource.data.favoriteFilters.size() <= 2
          )
        )
        && (
          !request.resource.data.keys().hasAny(["favoritesOnly"])
          || request.resource.data.favoritesOnly is bool
        )
        && request.resource.data.purchaseFilter in ["all", "bought", "pending"]
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy is string;
    }

    function isValidWorkspace() {
      return request.resource.data.keys().hasOnly([
          "openItemId",
          "deleteConfirm",
          "linkDeleteConfirm",
          "updatedAt",
          "updatedBy"
        ])
        && (
          !request.resource.data.keys().hasAny(["openItemId"])
          || request.resource.data.openItemId == null
          || request.resource.data.openItemId is string
        )
        && (
          !request.resource.data.keys().hasAny(["deleteConfirm"])
          || request.resource.data.deleteConfirm == null
          || isValidDeleteConfirm(request.resource.data.deleteConfirm)
        )
        && (
          !request.resource.data.keys().hasAny(["linkDeleteConfirm"])
          || request.resource.data.linkDeleteConfirm == null
          || isValidLinkDeleteConfirm(request.resource.data.linkDeleteConfirm)
        )
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy is string;
    }

    function isValidPresenceActivity(activity) {
      return activity is map
        && activity.keys().hasOnly(["itemId", "text"])
        && activity.itemId is string
        && activity.itemId.size() <= 120
        && activity.text is string
        && activity.text.size() <= 120;
    }

    function isValidPresence() {
      return request.resource.data.keys().hasOnly([
          "uid",
          "sessionId",
          "email",
          "name",
          "color",
          "label",
          "online",
          "x",
          "y",
          "draftItem",
          "activity",
          "updatedAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() <= 80
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 80
        && request.resource.data.color is string
        && request.resource.data.color.size() <= 16
        && request.resource.data.label is string
        && request.resource.data.label.size() <= 40
        && request.resource.data.online is bool
        && request.resource.data.x is number
        && request.resource.data.x >= 0
        && request.resource.data.x <= 1
        && request.resource.data.y is number
        && request.resource.data.y >= 0
        && request.resource.data.y <= 1
        && request.resource.data.draftItem is map
        && request.resource.data.draftItem.keys().hasOnly(["name", "value", "categories"])
        && request.resource.data.draftItem.name is string
        && request.resource.data.draftItem.name.size() <= 120
        && request.resource.data.draftItem.value is string
        && request.resource.data.draftItem.value.size() <= 40
        && request.resource.data.draftItem.categories is list
        && request.resource.data.draftItem.categories.size() <= 20
        && (
          !request.resource.data.keys().hasAny(["activity"])
          || isValidPresenceActivity(request.resource.data.activity)
        )
        && request.resource.data.updatedAt is timestamp;
    }

    match /items/{itemId} {
      allow read, delete: if isAllowed();
      allow create, update: if isAllowed() && isValidItem();
    }

    match /appState/{stateId} {
      allow read: if isAllowed();
      allow create, update: if isAllowed()
        && (
          (stateId == "filters" && isValidFilters())
          || (stateId == "workspace" && isValidWorkspace())
        );
      allow delete: if false;
    }

    match /presence/{sessionId} {
      allow read: if isAllowed();
      allow create, update: if isAllowed() && isValidPresence();
      allow delete: if isAllowed() && resource.data.uid == request.auth.uid;
    }
  }
}
